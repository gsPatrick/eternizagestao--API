  config: path.resolve(__dirname, 'src', 'config', 'database.js'),
  'models-path': path.resolve(__dirname, 'src', 'models'),
  'migrations-path': path.resolve(__dirname, 'migrations'),
  'seeders-path': path.resolve(__dirname, 'seeders'),
};
