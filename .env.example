# ===========================================
# Eterniza Gestão — API | Variáveis de ambiente
# Copie para .env e preencha (nunca commitar o .env)
# ===========================================
# REGRA DESTE ARQUIVO: só entra aqui variável que o CÓDIGO REALMENTE LÊ
# (process.env.X). Variável documentada e não lida engana quem opera o sistema:
# a pessoa preenche, acha que configurou, e a integração continua desligada.
# Cada bloco diz o que acontece quando o valor fica EM BRANCO.

# Ambiente da aplicação: development | test | production
# production endurece o sistema: exige JWT_SECRET/segredos de webhook e BLOQUEIA
# as simulações (baixa de cobrança e retorno de assinatura).
NODE_ENV=development

# Porta HTTP da API
APP_PORT=3000

# Prefixo público da API
APP_API_PREFIX=/api

# URL pública desta API (base para montar URLs de webhook — ex.: Evolution).
# Em produção, a URL externa alcançável pela internet.
APP_PUBLIC_URL=http://localhost:3333

# Fuso de OPERAÇÃO (cortes de vencimento, "hoje", janelas de notificação).
# Em branco => America/Sao_Paulo.
APP_TIMEZONE=America/Sao_Paulo

# Domínio base dos subdomínios das cidades (cidade.<BASE_DOMAIN>).
# Em branco => eternizagestao.com.br
BASE_DOMAIN=eternizagestao.com.br

# URLs de front usadas em links de e-mail/notificação (convite, portal).
# PANEL_URL em branco => cai em APP_WEB_URL; ambos em branco => http://localhost:3000
PANEL_URL=
APP_WEB_URL=
# Em branco => https://portal.local (o link do Portal da Família sai quebrado)
PORTAL_URL=

# Nº de proxies reversos à frente da API (rate-limit e IP real). Em branco => 1
TRUST_PROXY_HOPS=1

# Roda as migrations no boot. Ponha 'false' para desligar. Em branco => roda.
AUTO_MIGRATE=

# Backfill de certidões de perpetuidade no boot. 'false' desliga.
# Em branco => roda, em lotes de PERPETUITY_BACKFILL_BATCH (default 200).
PERPETUITY_BACKFILL=
PERPETUITY_BACKFILL_BATCH=200

# -------------------------------------------
# Banco de dados PostgreSQL (obrigatórias)
# -------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eterniza_gestao_dev
DB_USER=postgres
DB_PASSWORD=postgres

# Banco usado quando NODE_ENV=test (opcional)
DB_NAME_TEST=eterniza_gestao_test

# SSL na conexão com o banco (true em produção gerenciada: RDS, Supabase, etc.)
DB_SSL=false

# Pool de conexões (opcionais — defaults seguros no código)
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Loga SQL no console (true | false) — apenas para debug local
DB_LOGGING=false

# -------------------------------------------
# Filas / Redis (OPCIONAL)
# -------------------------------------------
# Com REDIS_URL (+ ioredis instalado): notificações e jobs rodam no worker
# (BullMQ), com retry/backoff, e os crons diários funcionam.
# EM BRANCO: fallback SÍNCRONO — o job roda dentro do próprio request e os
# agendamentos (varredura de vencidos/vencimentos) NÃO rodam.
REDIS_URL=

# -------------------------------------------
# Autenticação (JWT)
# -------------------------------------------
# OBRIGATÓRIA em produção (a API não sobe sem ela com NODE_ENV=production)
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# -------------------------------------------
# Criptografia de segredos em repouso (AES-256-GCM)
# -------------------------------------------
# Cifra os SEGREDOS das integrações por cidade (asaas.apiKey, smtp.password) no
# JSONB Tenant.settings.integrations. Chave de 32 bytes em base64 OU hex.
# OBRIGATÓRIA em produção (a API não cifra com chave default). Em dev cai num
# default fixo. Gere uma: `openssl rand -base64 32`  ou  `openssl rand -hex 32`.
# Segredos legados em TEXTO continuam sendo lidos; ao re-salvar viram `enc:v1:...`.
SECRETS_ENC_KEY=

# -------------------------------------------
# Storage de arquivos (fotos, ortofotos, PDFs, anexos)
# -------------------------------------------
# Driver: local (padrão). Futuro: s3, gcs — mesmo contrato do provider
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=uploads

# URLs assinadas de /files (LGPD): segredo do HMAC. Sem valor, cai no JWT_SECRET
# (obrigatório em produção) e, em dev, num fallback estável.
FILES_URL_SECRET=
# TTL padrão (segundos) das URLs assinadas devolvidas ao painel (default 3600).
FILES_URL_TTL_SECONDS=3600
# TTL (segundos) do link do documento enviado por e-mail/whatsapp (default 7 dias).
DOCUMENT_LINK_TTL_SECONDS=604800
# TTLs (segundos) das demais URLs assinadas — todos default 7 dias.
PHOTO_URL_TTL_SECONDS=604800
PUBLIC_PHOTO_URL_TTL_SECONDS=604800
ORTHOPHOTO_URL_TTL_SECONDS=604800
LOGO_URL_TTL_SECONDS=604800
# Tamanho máximo do upload de ortofoto (body limit). Em branco => 150mb
ORTHO_UPLOAD_LIMIT=150mb

# -------------------------------------------
# Geração de PDF dos documentos oficiais (provider providers/pdf)
# -------------------------------------------
# Driver: puppeteer (padrão, headless Chrome — fiel ao HTML/cores/logo) ou
# fallback (PDF simples sem browser). Com puppeteer, se o Chromium não estiver
# disponível, o provider cai automaticamente no fallback (não quebra a emissão).
PDF_DRIVER=puppeteer
# Timeouts do driver puppeteer (ms).
PDF_LAUNCH_TIMEOUT_MS=30000
PDF_RENDER_TIMEOUT_MS=30000
# Formato do papel do PDF oficial (A4 padrão).
DOCUMENT_PDF_FORMAT=A4

# -------------------------------------------
# Gateway de pagamento (boleto/PIX) — Asaas POR CIDADE
# -------------------------------------------
# NÃO existe chave global: a chave da conta Asaas é de CADA CIDADE e é salva
# pelo painel em Configurações › Integrações (cifrada com SECRETS_ENC_KEY).
# CIDADE SEM CHAVE: a emissão de cobrança é RECUSADA com
# PAYMENT_GATEWAY_NOT_CONFIGURED — nenhum boleto/PIX fictício é gravado.
# Segredo do HMAC do webhook mock/legado — OBRIGATÓRIO em produção.
PAYMENT_GATEWAY_WEBHOOK_SECRET=
# Token do webhook Asaas — FALLBACK global quando a cidade não define o seu.
ASAAS_WEBHOOK_TOKEN=
# Ajustes do cliente HTTP do Asaas (opcionais).
ASAAS_TIMEOUT_MS=15000
ASAAS_USER_AGENT=EternizaGestao

# -------------------------------------------
# WhatsApp (notificações automáticas) — Evolution API POR CIDADE
# -------------------------------------------
# UM servidor Evolution central (URL + chave globais) com UMA INSTÂNCIA por
# cidade (`cidade-<subdomain>`).
# EM BRANCO: a tela de conexão mostra honestamente "modo demonstração" (QR
# placeholder) e todo ENVIO é recusado — a notificação fica com status 'falha'
# e a mensagem de configuração; nunca 'enviada'.
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
# timeout das chamadas ao Evolution (ms) — em branco => 15000
EVOLUTION_TIMEOUT_MS=15000

# -------------------------------------------
# Assinatura digital de documentos
# -------------------------------------------
# NENHUM provedor real está contratado hoje: existe só o scaffold. Enviar
# documento para assinatura é RECUSADO com SIGNATURE_PROVIDER_NOT_CONFIGURED.
# (Para plugar Clicksign/D4Sign/ZapSign, ver src/providers/digital-signature.)
# Segredo do HMAC do webhook de assinatura — OBRIGATÓRIO em produção.
SIGNATURE_WEBHOOK_SECRET=

# -------------------------------------------
# E-mail (notificações transacionais)
# -------------------------------------------
# Precedência: 1) SMTP DA CIDADE (salvo pelo painel em Configurações ›
# Integrações, NÃO por env); 2) RESEND da plataforma (RESEND_API_KEY).
# SEM NENHUM DOS DOIS: o envio é RECUSADO com EMAIL_NOT_CONFIGURED e a
# notificação fica 'falha' com a instrução — nunca 'enviada'.
RESEND_API_KEY=
# Remetente da PLATAFORMA (usado pelo Resend: convites, onboarding do super_admin).
# Em branco => suporte@eternizagestao.com.br / "Eterniza Gestão".
EMAIL_FROM=
EMAIL_FROM_NAME=

# -------------------------------------------
# Agendamento das notificações (crons BullMQ — só rodam com REDIS_URL)
# -------------------------------------------
# Em branco => 09:00 (cobranças vencidas) e 09:30 (taxas a vencer), diários.
NOTIF_CRON_VENCIDOS=0 9 * * *
NOTIF_CRON_VENCIMENTOS=30 9 * * *

# -------------------------------------------
# Scripts (seed e smoke test) — não afetam a API em execução
# -------------------------------------------
# scripts/seed-admin.js — credenciais do super_admin inicial.
# Em branco => eternizagestaoadmin@gmail.com / eternizagestao (TROQUE em produção).
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
# scripts/seed-fantasma.js — senha da cidade de demonstração. Em branco => senha12345
SEED_FANTASMA_PASSWORD=
# scripts/smoke-test.js — base do teste de fumaça. Em branco => http://localhost:$APP_PORT/api
SMOKE_BASE_URL=
