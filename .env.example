# ===========================================
# Eterniza Gestão — API | Variáveis de ambiente
# Copie para .env e preencha (nunca commitar o .env)
# ===========================================

# Ambiente da aplicação: development | test | production
NODE_ENV=development

# Porta HTTP da API (usada pelo app.js na próxima etapa)
APP_PORT=3000

# Prefixo público da API
APP_API_PREFIX=/api

# URL pública desta API (base para montar a URL de webhooks — ex.: Evolution).
# Em produção, a URL externa alcançável pela internet. Dev: http://localhost:3333
APP_PUBLIC_URL=http://localhost:3333

# Origens liberadas no CORS (separadas por vírgula). Vazio/ausente => '*' (só dev!)
# Ex.: https://cidade1.plataforma.com,https://cidade2.plataforma.com
CORS_ORIGINS=

# -------------------------------------------
# Banco de dados PostgreSQL (obrigatórias)
# -------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eterniza_gestao_dev
DB_USER=postgres
DB_PASSWORD=postgres

# Banco usado quando NODE_ENV=test (opcional)
DB_NAME_TEST=eterniza_gestao_test

# SSL na conexão com o banco (true em produção gerenciada: RDS, Supabase, etc.)
DB_SSL=false

# Pool de conexões (opcionais — defaults seguros no código)
DB_POOL_MAX=10
DB_POOL_MIN=0
DB_POOL_ACQUIRE=30000
DB_POOL_IDLE=10000

# Loga SQL no console (true | false) — apenas para debug local
DB_LOGGING=false

# -------------------------------------------
# Autenticação (JWT)
# -------------------------------------------
# OBRIGATÓRIA em produção (a API não sobe sem ela com NODE_ENV=production)
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
JWT_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=7d

# -------------------------------------------
# Criptografia de segredos em repouso (AES-256-GCM)
# -------------------------------------------
# Cifra os SEGREDOS das integrações por cidade (asaas.apiKey, smtp.password) no
# JSONB Tenant.settings.integrations. Chave de 32 bytes em base64 OU hex.
# OBRIGATÓRIA em produção (a API não cifra com chave default). Em dev cai num
# default fixo. Gere uma: `openssl rand -base64 32`  ou  `openssl rand -hex 32`.
# Segredos legados em TEXTO continuam sendo lidos; ao re-salvar viram `enc:v1:...`.
SECRETS_ENC_KEY=

# -------------------------------------------
# Storage de arquivos (fotos, ortofotos, PDFs, anexos)
# -------------------------------------------
# Driver: local (padrão). Futuro: s3, gcs — mesmo contrato do provider
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=uploads

# URLs assinadas de /files (LGPD): segredo do HMAC. Sem valor, cai no JWT_SECRET
# (obrigatório em produção) e, em dev, num fallback estável.
FILES_URL_SECRET=
# TTL padrão (segundos) das URLs assinadas devolvidas ao painel (default 3600).
FILES_URL_TTL_SECONDS=3600
# TTL (segundos) do link do documento enviado por e-mail/whatsapp (default 7 dias).
DOCUMENT_LINK_TTL_SECONDS=604800

# -------------------------------------------
# Geração de PDF dos documentos oficiais (provider providers/pdf)
# -------------------------------------------
# Driver: puppeteer (padrão, headless Chrome — fiel ao HTML/cores/logo) ou
# fallback (PDF simples sem browser). Com puppeteer, se o Chromium não estiver
# disponível, o provider cai automaticamente no fallback (não quebra a emissão).
PDF_DRIVER=puppeteer
# Timeouts do driver puppeteer (ms).
PDF_LAUNCH_TIMEOUT_MS=30000
PDF_RENDER_TIMEOUT_MS=30000
# Formato do papel do PDF oficial (A4 padrão).
DOCUMENT_PDF_FORMAT=A4

# -------------------------------------------
# Gateway de pagamento (boleto/PIX)
# -------------------------------------------
# Driver: mock (padrão em dev). Produção: driver real com mesmas variáveis
PAYMENT_GATEWAY_PROVIDER=mock
PAYMENT_GATEWAY_API_KEY=
# gere um segredo forte; obrigatório em produção; usado como chave do HMAC-SHA256 sobre o corpo do webhook
PAYMENT_GATEWAY_WEBHOOK_SECRET=

# -------------------------------------------
# WhatsApp (notificações automáticas) — Evolution API POR CIDADE
# -------------------------------------------
# UM servidor Evolution central (URL + chave globais) com UMA INSTÂNCIA por
# cidade (`cidade-<subdomain>`). Sem EVOLUTION_API_URL o driver cai em `mock`
# (não quebra o dev: QR placeholder, envio só loga).
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
# timeout das chamadas ao Evolution (ms) — opcional
EVOLUTION_TIMEOUT_MS=15000

# (legado — não usados pelo driver Evolution)
WHATSAPP_PROVIDER=mock
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

# -------------------------------------------
# Assinatura digital de documentos
# -------------------------------------------
SIGNATURE_PROVIDER=mock
SIGNATURE_API_KEY=
# gere um segredo forte; obrigatório em produção; usado como chave do HMAC-SHA256 sobre o corpo do webhook
SIGNATURE_WEBHOOK_SECRET=

# -------------------------------------------
# E-mail (notificações transacionais)
# -------------------------------------------
# Driver: mock (padrão em dev — só loga, não envia). Produção exige um driver
# real (ex.: smtp) e as respectivas credenciais.
EMAIL_PROVIDER=mock
# remetente padrão (ex.: "Eterniza Gestão <no-reply@eterniza.app>"); cai em SMTP_USER se vazio
EMAIL_FROM=
# --- driver smtp (opcional; requer `npm i nodemailer`, dep não incluída) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
